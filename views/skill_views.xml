<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List -->

    <record id="view_orm_skill_list" model="ir.ui.view">
        <field name="name">orm.skill.list</field>
        <field name="model">orm.skill</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form -->

    <record id="view_orm_skill_form" model="ir.ui.view">
        <field name="name">orm.skill.form</field>
        <field name="model">orm.skill</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>

                    </group>

                    <notebook>

                        <page string="Employees">

                            <field name="employee_ids">

                                <list>

                                    <field name="name"/>

                                    <field name="department_id"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

    <!-- Action -->

    <record id="action_orm_skill" model="ir.actions.act_window">
        <field name="name">Skills</field>
        <field name="res_model">orm.skill</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>