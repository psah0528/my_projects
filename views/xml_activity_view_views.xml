<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =======================================================
                        Activity View (List)
    ======================================================== -->

    <record id="view_xml_activity_view_list" model="ir.ui.view">
        <field name="name">xml.activity.view.list</field>
        <field name="model">xml.activity.view</field>

        <field name="arch" type="xml">

            <list string="Activity View">

                <field name="name"/>

                <field name="employee"/>

                <field name="department"/>

                <field name="deadline"/>

                <field name="status"/>

                <field name="activity_ids" widget="list_activity"/>

            </list>

        </field>
    </record>


    <!-- =======================================================
                            Form View
    ======================================================== -->

    <record id="view_xml_activity_view_form" model="ir.ui.view">
        <field name="name">xml.activity.view.form</field>
        <field name="model">xml.activity.view</field>

        <field name="arch" type="xml">

            <form string="Activity View">

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>

                            <field name="employee"/>

                            <field name="department"/>

                        </group>

                        <group>

                            <field name="deadline"/>

                            <field name="status"/>

                        </group>

                    </group>

                    <group>

                        <field name="notes"/>

                    </group>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>


    <!-- =======================================================
                            Action
    ======================================================== -->

    <record id="action_xml_activity_view" model="ir.actions.act_window">

        <field name="name">Step 6 - Activity View</field>

        <field name="res_model">xml.activity.view</field>

        <field name="view_mode">list,form</field>

    </record>

</odoo>