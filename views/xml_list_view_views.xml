<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->

    <record id="view_xml_list_view_list" model="ir.ui.view">
        <field name="name">xml.list.view.list</field>
        <field name="model">xml.list.view</field>
        <field name="arch" type="xml">

            <list
                string="XML List View"
                default_order="sequence asc"
                multi_edit="1">

                <field name="sequence"/>

                <field
                    name="photo"
                    widget="image"
                    optional="show"/>

                <field name="employee_code"/>

                <field name="name"/>

                <field name="department"/>

                <field
                    name="salary"
                    sum="Total Salary"/>

                <field
                    name="progress"
                    widget="progressbar"/>

                <field
                    name="active"
                    widget="boolean_toggle"/>

                <field
                    name="status"
                    widget="badge"/>

            </list>

        </field>
    </record>

    <!-- Action -->

    <record id="action_xml_list_view" model="ir.actions.act_window">
        <field name="name">Step 1 - List View</field>
        <field name="res_model">xml.list.view</field>
        <field name="view_mode">list</field>
    </record>

</odoo>