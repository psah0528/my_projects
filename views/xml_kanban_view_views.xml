<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================
         Kanban View
    ========================== -->

    <record id="view_xml_kanban_view_kanban" model="ir.ui.view">
        <field name="name">xml.kanban.view.kanban</field>
        <field name="model">xml.kanban.view</field>
        <field name="arch" type="xml">

            <kanban>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_global_click oe_kanban_card">

                            <div class="text-center mb-3">
                                <field name="photo" widget="image"/>
                            </div>

                            <div>
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>

                            <div>
                                <field name="employee_code"/>
                            </div>

                            <div>
                                <field name="department"/>
                            </div>

                            <div>
                                ₹ <field name="salary"/>
                            </div>

                            <div class="mt-2">
                                <field name="status" widget="badge"/>
                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>


    <!-- =========================
         Form View
    ========================== -->

    <record id="view_xml_kanban_view_form" model="ir.ui.view">
        <field name="name">xml.kanban.view.form</field>
        <field name="model">xml.kanban.view</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>
                            <field name="employee_code"/>
                            <field name="department"/>
                            <field name="salary"/>

                        </group>

                        <group>

                            <field name="photo" widget="image"/>
                            <field name="status"/>
                            <field name="active"/>

                        </group>

                    </group>

                </sheet>

            </form>

        </field>

    </record>


    <!-- =========================
         Action
    ========================== -->

    <record id="action_xml_kanban_view" model="ir.actions.act_window">

        <field name="name">Step 4 - Kanban View</field>

        <field name="res_model">xml.kanban.view</field>

        <field name="view_mode">kanban,form</field>

    </record>

</odoo>