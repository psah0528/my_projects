<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Form View -->

    <record id="view_xml_form_view_form" model="ir.ui.view">
        <field name="name">xml.form.view.form</field>
        <field name="model">xml.form.view</field>
        <field name="arch" type="xml">

            <form string="Step 2 - Form View">

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>
                            <field name="employee_code"/>
                            <field name="email"/>
                            <field name="phone"/>

                        </group>

                        <group>

                            <field name="photo"/>
                            <field name="department"/>
                            <field name="salary"/>
                            <field name="joining_date"/>

                        </group>

                    </group>

                    <group>

                        <field name="active"/>
                        <field name="note"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- List View -->

    <record id="view_xml_form_view_list" model="ir.ui.view">
        <field name="name">xml.form.view.list</field>
        <field name="model">xml.form.view</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>
                <field name="employee_code"/>
                <field name="department"/>
                <field name="salary"/>

            </list>

        </field>
    </record>


    <!-- Action -->

    <record id="action_xml_form_view" model="ir.actions.act_window">
        <field name="name">Step 2 - Form View</field>
        <field name="res_model">xml.form.view</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>