<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Calendar View -->

    <record id="view_xml_calendar_view_calendar" model="ir.ui.view">
        <field name="name">xml.calendar.view.calendar</field>
        <field name="model">xml.calendar.view</field>
        <field name="arch" type="xml">

            <calendar
                string="Employee Meetings"
                date_start="meeting_date"
                color="department">

                <field name="name"/>
                <field name="department"/>
                <field name="status"/>

            </calendar>

        </field>
    </record>


    <!-- Form View -->

    <record id="view_xml_calendar_view_form" model="ir.ui.view">
        <field name="name">xml.calendar.view.form</field>
        <field name="model">xml.calendar.view</field>
        <field name="arch" type="xml">

            <form string="Step 5 - Calendar View">

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>
                            <field name="employee_code"/>
                            <field name="department"/>

                        </group>

                        <group>

                            <field name="meeting_date"/>
                            <field name="status"/>

                        </group>

                    </group>

                    <group>

                        <field name="notes"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- List View -->

    <record id="view_xml_calendar_view_list" model="ir.ui.view">
        <field name="name">xml.calendar.view.list</field>
        <field name="model">xml.calendar.view</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>
                <field name="employee_code"/>
                <field name="department"/>
                <field name="meeting_date"/>
                <field name="status"/>

            </list>

        </field>
    </record>


    <!-- Action -->

    <record id="action_xml_calendar_view" model="ir.actions.act_window">
        <field name="name">Step 5 - Calendar View</field>
        <field name="res_model">xml.calendar.view</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

</odoo>