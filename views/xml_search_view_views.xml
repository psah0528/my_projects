<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->

    <record id="view_xml_search_view_list" model="ir.ui.view">
        <field name="name">xml.search.view.list</field>
        <field name="model">xml.search.view</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>
                <field name="employee_code"/>
                <field name="department"/>
                <field name="status"/>
                <field name="salary"/>
                <field name="active"/>

            </list>

        </field>
    </record>


    <!-- Search View -->

    <record id="view_xml_search_view_search" model="ir.ui.view">
        <field name="name">xml.search.view.search</field>
        <field name="model">xml.search.view</field>
        <field name="arch" type="xml">

            <search>

                <field name="name"/>
                <field name="employee_code"/>
                <field name="department"/>

                <separator/>

                <filter
                    name="filter_active"
                    string="Active"
                    domain="[('active','=',True)]"/>

                <filter
                    name="filter_inactive"
                    string="Inactive"
                    domain="[('active','=',False)]"/>

                <separator/>

                <filter
                    name="draft"
                    string="Draft"
                    domain="[('status','=','draft')]"/>

                <filter
                    name="done"
                    string="Done"
                    domain="[('status','=','done')]"/>

                <group expand="0" string="Group By">

                    <filter
                        name="group_department"
                        string="Department"
                        context="{'group_by':'department'}"/>

                    <filter
                        name="group_status"
                        string="Status"
                        context="{'group_by':'status'}"/>

                </group>

            </search>

        </field>
    </record>


    <!-- Form View -->

    <record id="view_xml_search_view_form" model="ir.ui.view">
        <field name="name">xml.search.view.form</field>
        <field name="model">xml.search.view</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>
                        <field name="employee_code"/>
                        <field name="department"/>
                        <field name="status"/>
                        <field name="salary"/>
                        <field name="active"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- Action -->

    <record id="action_xml_search_view" model="ir.actions.act_window">
        <field name="name">Step 3 - Search View</field>
        <field name="res_model">xml.search.view</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>