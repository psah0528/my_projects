<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =====================================
                Pivot View
    ====================================== -->

    <record id="view_xml_pivot_view_pivot" model="ir.ui.view">
        <field name="name">xml.pivot.view.pivot</field>
        <field name="model">xml.pivot.view</field>
        <field name="arch" type="xml">

            <pivot string="Department Analysis">

                <field name="department" type="row"/>

                <field name="status" type="col"/>

                <field name="salary" type="measure"/>

                <field name="employee_count" type="measure"/>

            </pivot>

        </field>
    </record>


    <!-- =====================================
                List View
    ====================================== -->

    <record id="view_xml_pivot_view_list" model="ir.ui.view">
        <field name="name">xml.pivot.view.list</field>
        <field name="model">xml.pivot.view</field>

        <field name="arch" type="xml">

            <list>

                <field name="department"/>

                <field name="status"/>

                <field name="salary"/>

                <field name="employee_count"/>

            </list>

        </field>
    </record>


    <!-- =====================================
                Form View
    ====================================== -->

    <record id="view_xml_pivot_view_form" model="ir.ui.view">
        <field name="name">xml.pivot.view.form</field>
        <field name="model">xml.pivot.view</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="department"/>

                        <field name="status"/>

                        <field name="salary"/>

                        <field name="employee_count"/>

                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- =====================================
                Action
    ====================================== -->

    <record id="action_xml_pivot_view" model="ir.actions.act_window">

        <field name="name">Step 8 - Pivot View</field>

        <field name="res_model">xml.pivot.view</field>

        <field name="view_mode">pivot,list,form</field>

    </record>

</odoo>